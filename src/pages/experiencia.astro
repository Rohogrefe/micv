---
import Layout from "../layouts/Layout.astro";
import Card from "../components/Card.astro";
---

<Layout>
    <h1 class="text-3xl font-bold mb-6">Experiencia laboral</h1>

    <div class="space-y-6 max-w-2xl">
        <Card
            titulo="La Tiendita Dulce (emprendimiento propio)"
            fecha="2024 - Actualidad"
            lugar="Hersilia, Santa Fe"
            descripcion="Atención personalizada a clientes de forma presencial y online"
            descripcion2="Gestión de pedidos, entregas y organización de delivery"
            descripcion3="Manejo de caja y control de stock"
            titulo2="Logros"
            descripcion4="Aumento de ventas mediante promociones en redes sociales"
            descripcion5="Fidelización de clientes y mejora en la atención"
        />

        <Card
            titulo="Proyecto Web Personal"
            fecha="2026"
            lugar="Proyecto educativo"
            descripcion="Desarrollo de sitio web con Astro, Svelte y Tailwind CSS"
            descripcion2="Diseño responsive adaptable a distintos dispositivos"
            descripcion3="Creación de componentes reutilizables"
            titulo2="Logros"
            descripcion4="Creación de un CV online funcional"
            descripcion5="Mejora de habilidades en desarrollo web"
        />
    </div>
</Layout>
