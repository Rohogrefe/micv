---
const {
    titulo,
    fecha,
    lugar,
    descripcion,
    descripcion2,
    descripcion3,
    titulo2,
    descripcion4,
    descripcion5,
} = Astro.props;
---

<div class="bg-white shadow-md rounded-xl p-5 border-l-4 border-fuchsia-500">
    <h2 class="text-xl font-bold text-purple-700">{titulo}</h2>

    <p class="text-sm text-purple-400 mb-3">
        {fecha} • {lugar}
    </p>

    <ul class="list-disc list-inside text-gray-700 space-y-1 mb-4">
        <li>{descripcion}</li>
        <li>{descripcion2}</li>
        <li>{descripcion3}</li>
    </ul>

    <h3 class="font-semibold text-fuchsia-600">{titulo2}</h3>

    <ul class="list-disc list-inside text-gray-700 space-y-1 mt-2">
        <li>{descripcion4}</li>
        <li>{descripcion5}</li>
    </ul>
</div>
